timeout 150 'if [ "$(cat /sys/class/power_supply/AC/online)" = "0" ]; then brightnessctl -s set 10%; fi' resume 'brightnessctl -r'
timeout 540 'if [ "$(cat /sys/class/power_supply/AC/online)" = "1" ]; then brightnessctl -s set 10%; fi' resume 'brightnessctl -r'
timeout 180 'if [ "$(cat /sys/class/power_supply/AC/online)" = "0" ]; then loginctl lock-session; fi'
timeout 600 'if [ "$(cat /sys/class/power_supply/AC/online)" = "1" ]; then loginctl lock-session; fi'
timeout 210 'if [ "$(cat /sys/class/power_supply/AC/online)" = "0" ]; then niri msg action power-off-monitors; fi' resume 'niri msg action power-on-monitors'
timeout 660 'if [ "$(cat /sys/class/power_supply/AC/online)" = "1" ]; then niri msg action power-off-monitors; fi' resume 'niri msg action power-on-monitors'
timeout 900 'if [ "$(cat /sys/class/power_supply/AC/online)" = "0" ]; then systemctl suspend; fi'
before-sleep 'loginctl lock-session'
