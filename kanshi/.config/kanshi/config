# kanshi output profiles — ThinkPad P14s Gen 4 AMD
# kanshi detects connected outputs and applies the first matching profile.
# Niri has no runtime monitor IPC, so kanshi handles clamshell/dock switching.

# Docked, lid closed — external monitor only
profile docked-clamshell {
    output eDP-1 disable
    output DP-2 enable mode 3840x2160@60Hz position 0,0 scale 1
}

# Docked, lid open — dual monitor (laptop left, external right)
profile docked-open {
    output eDP-1 enable mode 1920x1200@60Hz position 0,0 scale 1
    output DP-2 enable mode 3840x2160@60Hz position 1920,0 scale 1
}

# Undocked — laptop display only
profile undocked {
    output eDP-1 enable mode 1920x1200@60Hz position 0,0 scale 1
}
